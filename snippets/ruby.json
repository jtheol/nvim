{
  "ActionAPI Model": {
    "prefix": "actmodel",
    "body": [
      "class ${1:${TM_FILENAME_BASE/(.*)/${1:/pascalcase}/}} < ApplicationRecord",
      "  include SchemaSync::Model",
      "  include ActionAPI::Model",
      "  $2",
      "  timestamps!",
      "",
      "  validates $3, presence: true",
      "",
      "  class ActionResponder < ActionAPI::ActionResponder",
      "    publish_action(:create) do",
      "      $4",
      "    end",
      "",
      "    def create",
      "      ${5:${1/(.*)/${1:/downcase}/}} = ${1}.new",
      "      attributes = params.slice(",
      "        $6",
      "      )",
      "      ${5}.assign_attributes(attributes)",
      "      ${5}.save!",
      "      ${5}",
      "    end",
      "",
      "    publish_action(:update) do",
      "      $7",
      "    end",
      "",
      "    def update(${5})",
      "      attributes = params.slice(",
      "        $8",
      "      )",
      "      ${5}.assign_attributes(attributes)",
      "      authorized_transaction!(${5}) do",
      "        ${5}.save!",
      "      end",
      "      ${5}",
      "    end",
      "",
      "    publish_action(:delete) {}",
      "",
      "    def delete(${5})",
      "      authorized_transaction!(${5}) do",
      "        ${5}.update!(deleted_at: Time.current)",
      "      end",
      "      ${5}",
      "    end",
      "  end",
      "",
      "  class ScopeResponder < ActionAPI::ActiveRecordScopeResponder",
      "    $9",
      "    def accessible_scope",
      "      Pundit.policy_scope!(request_context.actor, ${1})",
      "    end",
      "",
      "    def default_relation",
      "      accessible_scope",
      "    end",
      "  end",
      "end"
    ],
    "description": "ActionAPI model with ActionResponder and ScopeResponder"
  }
}
